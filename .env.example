# ──────────────────────────────────────────────
# 前端环境配置模板
# 复制此文件为 .env.development 后修改
# ──────────────────────────────────────────────

# Server 地址（不含端口，如 http://192.168.1.100 或 http://localhost）
VITE_SERVER_BASE_URL=http://localhost

# REST API 端口（对应 server config.py 的 PORT）
VITE_API_PORT=8000

# WebRTC 信令/流端口（对应 SRS HTTP 端口）
VITE_WEBRTC_PORT=8080
